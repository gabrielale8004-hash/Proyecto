---
const { title, sku, price, image } = Astro.props;
---

<div class="group bg-white flex flex-col h-full shadow-[0_4px_20px_rgba(0,0,0,0.03)] hover:shadow-[0_20px_40px_rgba(0,0,0,0.08)] transition-all duration-500 border border-zinc-100">
  
  <div class="aspect-square bg-[#EBECEF] m-2 flex items-center justify-center relative overflow-hidden">
    <img 
      src={image} 
      alt={title} 
      class="max-h-[65%] object-contain group-hover:scale-110 transition-transform duration-700 z-10" 
    />
    <span class="absolute text-[120px] font-black text-black/3 -bottom-10 -right-5 italic select-none">TESK</span>
  </div>

  <div class="p-6 flex flex-col flex-1">
    <div class="flex justify-between items-start mb-4">
        <div>
            <h3 class="text-[13px] font-black uppercase leading-tight text-black tracking-tight">{title}</h3>
            <p class="text-[9px] text-zinc-400 font-bold uppercase tracking-tighter mt-1">Ref: {sku}</p>
        </div>
    </div>
    
    <div class="flex justify-between items-end mt-auto pt-6 border-t border-zinc-50">
      <div class="flex flex-col">
          <p class="text-[8px] font-bold text-zinc-400 uppercase tracking-widest mb-1">Price</p>
          <span class="text-2xl font-black text-black tracking-tighter">{price}</span>
      </div>
      
      <button class="bg-[#ffcc00] w-12 h-12 text-black hover:bg-black hover:text-[#ffcc00] transition-all flex items-center justify-center shadow-lg shadow-[#ffcc00]/20 hover:shadow-black/20">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
      </button>
    </div>
  </div>
</div>
