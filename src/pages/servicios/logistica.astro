---
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Logística y Despacho | Suministros Tesk">
  <main class="bg-[#050505] min-h-screen text-white antialiased">
    
    <!-- Hero: Menos difuminado, más nitidez -->
    <section class="relative h-[60vh] flex items-center overflow-hidden border-b border-white/5">
      <div class="absolute inset-0 z-0">
        <!-- Degradado más sutil para no tapar las letras -->
        <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-transparent to-transparent z-10"></div>
        <img 
          src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&q=80" 
          class="w-full h-full object-cover grayscale opacity-25"
          alt="Logística"
        />
      </div>
      
      <div class="container mx-auto px-6 relative z-20">
        <a href="/" class="inline-flex items-center gap-3 text-[#ffcc00] uppercase text-[10px] font-black tracking-[0.4em] mb-8 hover:opacity-70 transition-all">
          <Icon name="lucide:arrow-left" class="w-4 h-4" /> Inicio
        </a>
        <!-- Título nítido sin sombras raras -->
        <h1 class="text-7xl md:text-[100px] font-black uppercase tracking-tighter leading-[0.8] mb-6">
          LOGÍSTICA <br/> <span class="text-[#ffcc00]">IMPLACABLE</span>
        </h1>
        <p class="max-w-xl text-gray-300 font-medium leading-relaxed">
          Infraestructura logística optimizada para que el suministro de su empresa en Valencia y Guacara jamás se detenga.
        </p>
      </div>
    </section>

    <!-- Cajas Organizadas con Brillo Constante -->
    <section class="py-24 container mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        
        <!-- Caja 1 -->
        <div class="relative group">
          <!-- El "Brillo" de fondo visible por defecto -->
          <div class="absolute inset-0 bg-[#ffcc00]/5 blur-[40px] rounded-full opacity-100 transition-all group-hover:bg-[#ffcc00]/10"></div>
          
          <div class="relative p-10 bg-[#0a0a0a] border border-[#ffcc00]/20 rounded-[32px] h-full flex flex-col hover:border-[#ffcc00]/50 transition-colors duration-500">
            <Icon name="lucide:truck" class="w-10 h-10 text-[#ffcc00] mb-6" />
            <h3 class="text-xl font-bold text-white uppercase mb-4 tracking-tight">Flota Local</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              Unidades dedicadas para despachos inmediatos en Valencia, Guacara y Los Guayos, cubriendo toda la zona industrial del estado Carabobo.
            </p>
          </div>
        </div>

        <!-- Caja 2 -->
        <div class="relative group">
          <div class="absolute inset-0 bg-[#ffcc00]/5 blur-[40px] rounded-full opacity-100"></div>
          
          <div class="relative p-10 bg-[#0a0a0a] border border-[#ffcc00]/20 rounded-[32px] h-full flex flex-col hover:border-[#ffcc00]/50 transition-colors duration-500">
            <Icon name="lucide:clock" class="w-10 h-10 text-[#ffcc00] mb-6" />
            <h3 class="text-xl font-bold text-white uppercase mb-4 tracking-tight">Just-in-Time</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              Eficiencia en tiempos de entrega. Suministramos lo que su línea de producción necesita en el momento exacto, reduciendo costos de almacenamiento.
            </p>
          </div>
        </div>

        <!-- Caja 3 -->
        <div class="relative group">
          <div class="absolute inset-0 bg-[#ffcc00]/5 blur-[40px] rounded-full opacity-100"></div>
          
          <div class="relative p-10 bg-[#0a0a0a] border border-[#ffcc00]/20 rounded-[32px] h-full flex flex-col hover:border-[#ffcc00]/50 transition-colors duration-500">
            <Icon name="lucide:package-check" class="w-10 h-10 text-[#ffcc00] mb-6" />
            <h3 class="text-xl font-bold text-white uppercase mb-4 tracking-tight">Embalaje Seguro</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              Toda nuestra mercancía se entrega clasificada y protegida bajo estándares industriales, facilitando la recepción y auditoría de inventario.
            </p>
          </div>
        </div>

      </div>
    </section>

    <!-- Sección de Cierre Simple -->
    <section class="pb-24 container mx-auto px-6 text-center">
      <div class="max-w-3xl mx-auto py-16 border-t border-white/5">
        <h2 class="text-2xl font-bold uppercase tracking-[0.2em] mb-4">Suministros Tesk ©</h2>
        <p class="text-gray-500 text-xs uppercase tracking-widest">Compromiso Industrial • Carabobo, Venezuela</p>
      </div>
    </section>

  </main>
</Layout>