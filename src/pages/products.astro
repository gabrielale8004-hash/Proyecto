---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Catálogo | Tesk">
  <div class="bg-white py-16 px-12">
    <div class="mb-12">
      <p class="text-[#ffcc00] font-bold text-xs uppercase">Catálogo</p>
      <p class="text-4xl font-black uppercase italic text-black">Nuestros Productos</p>
    </div>

    <div class="flex justify-between gap-5">
      <div class="flex-1 border border-black p-5 bg-gray-50">
        <img src="/unnamed.png" class="h-40 mx-auto" />
        <p class="font-bold mt-4 uppercase">Tornillería</p>
        <p class="text-sm text-gray-600">Consultar Precio</p>
      </div>
      <div class="flex-1 border border-black p-5 bg-gray-50">
        <img src="/llave.jpeg" class="h-40 mx-auto" />
        <p class="font-bold mt-4 uppercase">Herramientas</p>
        <p class="text-sm text-gray-600">Consultar Precio</p>
      </div>
      <div class="flex-1 border border-black p-5 bg-gray-50">
        <img src="/bota.jpeg" class="h-40 mx-auto" />
        <p class="font-bold mt-4 uppercase">Seguridad</p>
        <p class="text-sm text-gray-600">Consultar Precio</p>
      </div>
    </div>
  </div>
</Layout>