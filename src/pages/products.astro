---
import Layout from "../layouts/Layout.astro";
import Tarjeta from "../components/Tarjeta.astro";
const listadoProductos = [
    {
        title: "Tornillo Hexagonal G5",
        description:
            "Tornillería de alta resistencia para uso industrial y automotriz.",
        image: "/unnamed.png",
    },
    {
        title: "Llave de Torque Prof.",
        description:
            "Herramienta de precisión con mango ergonómico y ajuste rápido.",
        image: "/llave.jpeg",
    },
    {
        title: "Bota de Seguridad",
        description:
            "Calzado con punta de acero y suela antideslizante certificada.",
        image: "/bota.jpeg",
    },
];
---

<Layout title="Catálogo | Tesk">
    <div class="bg-gray-200 py-16 px-12">
        <div class="mb-12">
            <p class="text-[#ffcc00] font-bold text-xs uppercase">Catálogo</p>
            <p class="text-4xl font-black uppercase italic text-black">
                Nuestros Productos
            </p>
        </div>

        <div class="flex justify-between gap-6">
            {
                listadoProductos.map((producto) => (
                    <Tarjeta
                        title={producto.title}
                        description={producto.description}
                        image={producto.image}
                    />
                ))
            }
        </div>

        <div class="flex justify-between gap-6 mt-6">
            <div
                class="flex-1 p-8 bg-black-500 border border-dashed border-gray-900 flex items-center justify-center text-black italic text-sm"
            >
                Más productos próximamente...
            </div>
        </div>
    </div>
</Layout>
