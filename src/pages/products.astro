---
import Layout from "../layouts/Layout.astro";
import Tarjeta from "../components/Tarjeta.astro";

const listadoProductos = [
    {
        title: "Tornillo Hexagonal G5",
        sku: "TESK-001",
        price: "$12.00",
        description: "Tornillería de alta resistencia para uso industrial y automotriz.",
        image: "/unnamed.png",
    },
    {
        title: "Llave de Torque Prof.",
        sku: "TESK-002",
        price: "$85.00",
        description: "Herramienta de precisión con mango ergonómico y ajuste rápido.",
        image: "/llave.jpeg",
    },
    {
        title: "Bota de Seguridad",
        sku: "TESK-003",
        price: "$45.00",
        description: "Calzado con punta de acero y suela antideslizante certificada.",
        image: "/bota.jpeg",
    },
];
---

<Layout title="Catálogo | Tesk">
  <div class="flex min-h-screen bg-[#F2F2F2] font-sans">
    
    <aside class="w-64 bg-[#1A1A1A] p-8 hidden lg:block shadow-2xl">
      <h2 class="text-[10px] font-black uppercase tracking-[0.3em] mb-10 text-zinc-500">Categorías</h2>
      <nav class="flex flex-col gap-4">
        <a href="#" class="flex items-center gap-3 bg-[#ffcc00] p-4 font-black text-[11px] uppercase tracking-tighter text-black shadow-lg shadow-[#ffcc00]/10">
          Tornillería
        </a>
        <a href="#" class="flex items-center gap-3 p-4 font-bold text-[11px] uppercase tracking-tighter text-zinc-400 hover:text-white hover:bg-white/5 transition-all">
          Herramientas
        </a>
        <a href="#" class="flex items-center gap-3 p-4 font-bold text-[11px] uppercase tracking-tighter text-zinc-400 hover:text-white hover:bg-white/5 transition-all">
          Seguridad
        </a>
      </nav>
    </aside>

    <main class="flex-1 py-16 px-10">
      <div class="max-w-287.5 mx-auto">
        
        <header class="mb-20 flex justify-between items-end">
          <div>
            <div class="flex items-center gap-3 mb-2">
                <span class="w-8 h-0.5 bg-[#ffcc00]"></span>
                <p class="text-[#ffcc00] font-black text-[10px] uppercase tracking-[0.5em]">Inventory 2026</p>
            </div>
            <h1 class="text-6xl font-black uppercase italic text-black tracking-tighter leading-none">
              Nuestros <span class="text-zinc-400/50">Productos</span>
            </h1>
          </div>
          <div class="hidden md:block text-right">
            <p class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest">Suministros Tesk ©</p>
            <p class="text-[10px] font-bold text-black uppercase tracking-widest">Valencia, Venezuela</p>
          </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-10">
          {
            listadoProductos.map((producto) => (
              <Tarjeta 
                title={producto.title} 
                sku={producto.sku}
                price={producto.price}
                description={producto.description}
                image={producto.image} 
              />
            ))
          }
        </div>

        <div class="mt-12 p-8 border border-dashed border-zinc-300 flex items-center justify-center text-zinc-500 italic text-sm">
            Más productos próximamente...
        </div>

      </div>
    </main>
  </div>
</Layout>