---
import Layout from '../layouts/Layout.astro';

// Usamos la imagen técnica que pediste con más visibilidad
const fondoImagen = "https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?q=80&w=2070&auto=format&fit=crop";
const nombreArchivoPDF = "CATÁLOGO @TESKSUMINISTROS.pdf";
---

<Layout title="Descarga de Catálogo | Suministros Tesk">
  <main class="relative min-h-screen flex items-center justify-center bg-black overflow-hidden selection:bg-[#E2E61B] selection:text-black">
    
    <!-- FONDO CON ALTA VISIBILIDAD -->
    <div class="absolute inset-0 z-0">
      <img 
        src={fondoImagen} 
        class="w-full h-full object-cover opacity-60 animate-subtle-zoom" 
        alt="Industrial Workshop"
      />
      <!-- Gradiente radial para enfocar el centro y oscurecer bordes -->
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_transparent_0%,_rgba(0,0,0,0.8)_100%)]"></div>
      <div class="absolute inset-0 bg-black/40"></div>
    </div>

    <!-- CONTENIDO PRINCIPAL -->
    <section class="relative z-10 w-full max-w-5xl px-6 flex flex-col items-center">
      
      <!-- ETIQUETA DE VERSIÓN -->
      <div class="mb-6 animate-fade-in">
        <span class="px-4 py-1.5 rounded-full border border-[#E2E61B]/40 bg-[#E2E61B]/10 text-[#E2E61B] text-[10px] font-black uppercase tracking-[0.4em] shadow-[0_0_20px_rgba(226,230,27,0.2)]">
          Versión Digital 2025
        </span>
      </div>

      <!-- TÍTULO IMPACTANTE (AMARILLO TESK) -->
      <div class="text-center mb-14 animate-reveal-up">
        <h1 class="text-6xl md:text-8xl font-black text-white tracking-tighter uppercase italic leading-[0.85]">
          DESCARGAR <br/> 
          <span class="text-[#E2E61B] drop-shadow-[0_0_30px_rgba(226,230,27,0.4)]">
            CATÁLOGO COMPLETO
          </span>
        </h1>
        <p class="mt-6 text-slate-200 text-sm md:text-lg max-w-2xl mx-auto font-bold uppercase tracking-wide opacity-80">
          Acceda a nuestra lista detallada de ingeniería y suministros <br class="hidden md:block"/> de alta resistencia en formato de alta resolución.
        </p>
      </div>

      <!-- TARJETA DE DESCARGA (GLASSMORPHISM PURO) -->
      <div class="relative w-full max-w-4xl animate-reveal-up-delayed">
        <!-- Borde de luz sutil -->
        <div class="absolute -inset-[1px] bg-gradient-to-r from-transparent via-[#E2E61B]/30 to-transparent rounded-[3rem]"></div>
        
        <div class="relative backdrop-blur-xl bg-black/40 border border-white/10 rounded-[3rem] p-10 md:p-16 flex flex-col md:flex-row items-center justify-between gap-12 shadow-2xl">
          
          <div class="text-center md:text-left space-y-2">
            <h3 class="text-white font-black text-2xl md:text-3xl uppercase italic tracking-tight">ESPECIFICACIONES <br/> TÉCNICAS</h3>
            <div class="flex items-center justify-center md:justify-start gap-4 pt-2">
                <span class="text-[#E2E61B] font-mono text-xs font-bold uppercase tracking-widest">PDF</span>
                <span class="w-1.5 h-1.5 rounded-full bg-white/20"></span>
                <span class="text-white/60 font-mono text-xs uppercase tracking-widest">48.5 MB</span>
                <span class="w-1.5 h-1.5 rounded-full bg-white/20"></span>
                <span class="text-white/60 font-mono text-xs uppercase tracking-widest">120 PÁG</span>
            </div>
          </div>

          <!-- BOTÓN AMARILLO TESK (IGUAL AL NAV) -->
          <a 
            href={`/${nombreArchivoPDF}`}
            download={nombreArchivoPDF}
            class="group relative flex items-center gap-8 bg-[#E2E61B] hover:bg-white text-black font-black py-7 px-14 rounded-2xl transition-all duration-500 shadow-[0_20px_50px_-10px_rgba(226,230,27,0.5)] hover:shadow-[0_20px_50px_-10px_rgba(255,255,255,0.3)] hover:-translate-y-1"
          >
            <span class="text-xl md:text-2xl uppercase tracking-tighter">DESCARGAR AHORA</span>
            <div class="bg-black text-white p-3 rounded-xl group-hover:scale-110 transition-transform duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
            </div>
          </a>
        </div>
      </div>

      <!-- COORDENADAS DISCRETAS -->
      <div class="mt-12 opacity-40 flex gap-8 text-[10px] font-mono text-white tracking-[0.5em] uppercase">
        <span>10.1620° N, 67.9299° W</span>
        <span>Valencia, VZLA</span>
      </div>

    </section>
  </main>
</Layout>

<style>
  @keyframes subtleZoom {
    from { transform: scale(1.05); }
    to { transform: scale(1.15); }
  }
  .animate-subtle-zoom { animation: subtleZoom 25s infinite alternate ease-in-out; }

  @keyframes revealUp {
    0% { opacity: 0; transform: translateY(40px); filter: blur(10px); }
    100% { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .animate-reveal-up { animation: revealUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .animate-reveal-up-delayed { animation: revealUp 1.2s 0.2s cubic-bezier(0.16, 1, 0.3, 1) both; }
  
  .animate-fade-in { animation: fadeIn 2s ease-out forwards; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
</style>