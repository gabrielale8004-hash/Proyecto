---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section class="bg-white w-full py-24">
    <div class="max-w-[1400px] mx-auto px-40 flex flex-col gap-12">
      
      <div class="flex flex-col gap-2">
        <p class="text-[#9c8414] font-bold text-sm uppercase tracking-widest">Catálogo</p>
        <h2 class="text-4xl font-bold text-black uppercase italic">Nuestros Productos</h2>
        <div class="h-1 w-20 bg-[#ffcc00]"></div>
      </div>

      <div class="flex flex-wrap gap-10 justify-between">
        
        <div class="flex flex-col gap-4 px-6 bg-white p-6 border-b-4 border-transparent hover:border-[#ffcc00] transition-all group shadow-md hover:shadow-2xl">
          <div class="bg-gray-100 h-64 w-full flex items-center justify-center overflow-hidden">
             <div class="w-24 h-24 bg-gray-300 rounded-full flex items-center justify-center">
               <span class="text-gray-500 font-bold uppercase text-[10px]">Tornillo</span>
             </div>
          </div>
          <div class="flex flex-col gap-1">
            <p class="text-xs text-gray-500 uppercase">Tornillería</p>
            <p class="font-bold text-lg text-black uppercase">Tornillo Hexagonal G5</p>
            <p class="text-yellow-700 font-bold">$0.00</p>
          </div>
          <button class="bg-[#111] text-white py-3 font-bold uppercase text-xs group-hover:bg-[#ffcc00] group-hover:text-black transition-colors">
            Ver detalles
          </button>
        </div>

        <div class="flex flex-col gap-4 px-6 bg-white p-6 border-b-4 border-transparent hover:border-[#ffcc00] transition-all group shadow-md hover:shadow-2xl">
          <div class="bg-gray-100 h-64 w-full flex items-center justify-center overflow-hidden">
             <div class="w-24 h-24 bg-gray-300 rounded-full flex items-center justify-center">
               <span class="text-gray-500 font-bold uppercase text-[10px]">Anclaje</span>
             </div>
          </div>
         
        <anclaje />

        <div class="flex flex-col gap-4 w-[300px] bg-white p-6 border-b-4 border-transparent hover:border-[#ffcc00] transition-all group shadow-md hover:shadow-2xl">
          <div class="bg-gray-100 h-64 w-full flex items-center justify-center overflow-hidden">
             <div class="w-24 h-24 bg-gray-300 rounded-full flex items-center justify-center">
               <span class="text-gray-500 font-bold uppercase text-[10px]">Llave</span>
             </div>
          </div>
          <div class="flex flex-col gap-1">
            <p class="text-xs text-gray-500 uppercase">Herramientas</p>
            <p class="font-bold text-lg text-black uppercase">Llave de Torque Prof.</p>
            <p class="text-yellow-700 font-bold">$0.00</p>
          </div>
          <button class="bg-[#111] text-white py-3 font-bold uppercase text-xs group-hover:bg-[#ffcc00] group-hover:text-black transition-colors">
            Ver detalles
          </button>
        </div>

      </div>
    </div>
  </section>
</Layout>