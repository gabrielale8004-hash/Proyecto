---
import Layout from "../layouts/Layout.astro";
import Tarjeta from "../components/Tarjeta.astro";
---

<Layout title="Catálogo | Tesk">
  <div class="bg-white py-16 px-12">
    <div class="mb-12">
      <p class="text-[#ffcc00] font-bold text-xs uppercase">Catálogo</p>
      <p class="text-4xl font-black uppercase italic text-black">Nuestros Productos</p>
    </div>

    <div class="flex justify-between gap-5">
      <div class="flex-1 border border-black p-5 bg-gray-50">
        <img src="/unnamed.png" class="h-40 mx-auto" />
        <p class="font-bold mt-4 uppercase">Tornillería</p>
        <p class="text-sm text-gray-600">Consultar Precio</p>
    <div class="max-w-300 mx-auto">
      
      <div class="mb-12 border-l-4 border-[#ffcc00] pl-6">
        <p class="text-[#ffcc00] font-bold text-xs uppercase">Inventario Completo</p>
        <p class="text-4xl font-black uppercase italic text-black">Nuestros Productos</p>
      </div>
      <div class="flex-1 border border-black p-5 bg-gray-50">
        <img src="/llave.jpeg" class="h-40 mx-auto" />
        <p class="font-bold mt-4 uppercase">Herramientas</p>
        <p class="text-sm text-gray-600">Consultar Precio</p>

      <div class="flex justify-between gap-6">
        
        <Tarjeta 
          title="Tornillo Hexagonal G5" 
          description="Tornillería de alta resistencia para uso industrial y automotriz." 
          image="/unnamed.png" 
        />

        <Tarjeta 
          title="Llave de Torque Prof." 
          description="Herramienta de precisión con mango ergonómico y ajuste rápido." 
          image="/llave.jpeg" 
        />

        <Tarjeta 
          title="Bota de Seguridad" 
          description="Calzado con punta de acero y suela antideslizante certificada." 
          image="/bota.jpeg" 
        />

      </div>
      <div class="flex-1 border border-black p-5 bg-gray-50">
        <img src="/bota.jpeg" class="h-40 mx-auto" />
        <p class="font-bold mt-4 uppercase">Seguridad</p>
        <p class="text-sm text-gray-600">Consultar Precio</p>

      <div class="flex justify-between gap-6 mt-6">
         <div class="flex-1 p-8 bg-gray-50 border border-dashed border-gray-300 flex items-center justify-center text-gray-400 italic text-sm">
           Más productos próximamente...
         </div>
      </div>

    </div>
  </div>
</Layout>