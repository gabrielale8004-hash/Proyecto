---
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<header class="negro">
		<div class="contenido">
			<p class="tag">atención al cliente</p>
			<h1>CONTÁCTANOS PARA <br> <span class="amarillo">ASESORÍA TÉCNICA</span></h1>
			<p class="sub">
				estamos listos para ayudarte con tus proyectos industriales. 
				escríbenos para cotizaciones por volumen o dudas sobre anclajes.
			</p>
		</div>
	</header>

	<section class="gris">
		<div class="columnas">
			
			<div class="caja">
				<p class="tit-caja">UBICACIÓN</p>
				<p>Guacara, <br>carabobo, venezuela.</p>
			</div>

			<div class="caja">
				<p class="tit-caja">TELÉFONOS</p>
				<p>ventas: +58 245-5646129 <br> soporte: +58 245-5646129</p>
			</div>

			<div class="caja">
				<p class="tit-caja">HORARIOS</p>
				<p>lunes a sabado <br> 9:00 am - 6:00 pm</p>
			</div>

		</div>
	</section>
</Layout>

<style>
	/* estilo para el fondo negro igual que el anterior */
	.negro {
		background: #111;
		color: white;
		padding: 100px 50px;
	}

	.tag {
		background: #ffcc00;
		color: black;
		display: inline-block;
		padding: 3px 10px;
		font-weight: bold;
		font-size: 12px;
		margin-bottom: 20px;
	}

	h1 {
		font-size: 50px;
		font-style: italic;
		line-height: 1;
		margin-bottom: 20px;
	}

	.amarillo { color: #ffcc00; }

	.sub {
		color: #ccc;
		max-width: 550px;
		line-height: 1.6;
	}

	/* estilo para los cuadros de contacto */
	.gris {
		background: #efefef;
		padding: 80px 20px;
	}

	.columnas {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
	}

	.caja {
		width: 30%;
	}

	.tit-caja {
		font-weight: bold;
		margin-bottom: 10px;
		font-size: 18px;
		color: black;
	}

	p {
		color: #444;
		line-height: 1.5;
	}
</style>