---
import Tarjeta from "../components/Tarjeta.astro";
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout>
  <header class="flex bg-[#111] text-white pt-24 pb-24">
    <div class="py-40 px-40 flex flex-col gap-8">
      
      <p class="bg-[#ffcc00] text-black font-bold text-base w-fit px-6 py-1.5 uppercase tracking-wider">
        expertos industriales
      </p>

      <h1 class="text-7xl font-bold uppercase">
        ESPECIALISTAS EN <br />
        <span class="text-[#ffcc00]">TORNILLERÍA</span> <br />
        Y HERRAMIENTAS
      </h1>

      <p class="text-gray-400 py-40 text-lg leading-relaxed">
        precisión de grado industrial para proyectos que requieren resistencia
        absoluta. suministros certificados para ingeniería y construcción.
      </p>

      <div class="flex gap-8 mt-6">
        <button class="bg-[#ffcc00] text-black font-bold h-14 w-60 uppercase text-sm">
          explorar catálogo
        </button>
        <button class="border-2 border-white text-white font-bold h-14 w-60 uppercase text-sm">
          fichas técnicas
        </button>
      </div>
    </div>
  </header>

  <section class="bg-[#f3f4f6] py-24">
    <div class="flex gap-12">

      <Tarjeta titulo="CERTIFICACIÓN ISO" icon="line-md--home-twotone" subtitle="Cumplimos con estándares internacionales de seguridad en cada pieza." ></Tarjeta>
      <Tarjeta titulo="LOGÍSTICA PESADA" icon="typcn--shopping-cart" subtitle="Entregas directas a obra con flota propia preparada para gran tonelaje." ></Tarjeta>
      <Tarjeta titulo="ASESORÍA TÉCNICA" icon="healthicons--magnifying-glass" subtitle="Cálculo de necesidades de anclaje y torque profesional por ingenieros." ></Tarjeta>
    </div>
  </section>

<div>

<p class="uppercase font-bold text-lg">inventario crítico</p>


</div>

</Layout>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  body {
    overflow-x: hidden;
  }
</style>