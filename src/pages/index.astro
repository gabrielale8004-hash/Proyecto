---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";

const servicios = [
  { 
    icon: "lucide:award", 
    title: "Resistencia", 
    desc: "Tornillería certificada bajo normas internacionales de calidad superior.",
    href: "/servicios/calidad" 
  },
  { 
    icon: "lucide:truck", 
    title: "Despacho", 
    desc: "Logística optimizada para entregas justo a tiempo en toda la región.",
    href: "/servicios/logistica" 
  },
  { 
    icon: "lucide:settings-2", 
    title: "Soporte", 
    desc: "Asesoría técnica especializada para la selección exacta de medidas.",
    href: "/servicios/asesoria" 
  }
];
---

<Layout title="Suministros Tesk | Potencia Industrial">
  <main class="bg-[#050505] antialiased">
    
    <!-- Hero Section: Texto elevado y ruta /products corregida -->
    <section class="relative min-h-screen flex items-start pt-20 md:pt-32 lg:pt-40 overflow-hidden">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#050505]/60 to-[#050505] z-20"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-[#050505] via-[#050505]/20 to-transparent z-20"></div>
        
        <img 
          src="https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?auto=format&fit=crop&q=80" 
          class="w-full h-full object-cover grayscale opacity-35 scale-110 object-right"
          alt="Suministros Tesk"
        />
      </div>

      <div class="container mx-auto px-6 relative z-30">
        <div class="max-w-4xl">
          <!-- Ubicación estilo original -->
          <div class="inline-flex items-center gap-3 px-4 py-2 bg-black/60 border border-white/10 rounded-full backdrop-blur-md mb-8">
            <span class="w-2 h-2 rounded-full bg-[#ffcc00] shadow-[0_0_10px_#ffcc00]"></span>
            <p class="text-white/80 font-bold uppercase tracking-[0.3em] text-[9px]">Guacara • Carabobo • Venezuela</p>
          </div>

          <h1 class="text-6xl md:text-9xl font-black text-white leading-[0.8] uppercase mb-10 tracking-tighter">
            FUERZA EN <br />
            <span class="text-[#ffcc00] drop-shadow-[0_0_50px_rgba(255,204,0,0.4)]">CADA GIRO</span>
          </h1>

          <div class="flex flex-col sm:flex-row gap-10 items-center">
            <!-- RUTA CORREGIDA A /products -->
            <a href="/products" class="w-full sm:w-auto text-center px-10 py-5 bg-[#ffcc00] text-black font-black uppercase text-xs tracking-[0.2em] transition-all hover:bg-white hover:scale-105 shadow-[0_20px_50px_rgba(255,204,0,0.2)]">
              Explorar Inventario →
            </a>
            <a href="#servicios" class="text-white/50 hover:text-white font-bold uppercase text-[10px] tracking-[0.4em] transition-all border-b border-white/10 hover:border-[#ffcc00] pb-1">
              Nuestros Servicios
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Sección de Servicios: Caja 100% interactiva -->
    <section id="servicios" class="relative py-32 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="mb-20">
          <p class="text-[#ffcc00] font-bold uppercase tracking-[0.5em] text-[10px] mb-4">Respaldo Industrial</p>
          <h2 class="text-5xl md:text-7xl font-black text-white uppercase tracking-tighter leading-none">
            COMPROMISO Y <br/>
            <span class="italic text-transparent bg-clip-text bg-gradient-to-r from-white to-[#444] pr-10 pb-4 inline-block">PRECISIÓN</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          { servicios.map((item) => (
            <div class="group relative p-[1px] rounded-[32px] bg-gradient-to-b from-white/10 to-transparent hover:from-[#ffcc00]/50 transition-all duration-500 hover:-translate-y-2">
              <div class="relative h-full p-10 bg-[#080808] rounded-[31px] flex flex-col overflow-hidden">
                
                <!-- LINK TOTAL: Ahora toda la caja es el botón -->
                <a href={item.href} class="absolute inset-0 z-30 cursor-pointer">
                   <span class="sr-only">Ver más sobre {item.title}</span>
                </a>

                <div class="mb-8 relative z-10">
                  <div class="w-14 h-14 bg-[#121212] border border-white/10 rounded-2xl flex items-center justify-center text-[#ffcc00] transition-all duration-500 group-hover:bg-[#ffcc00] group-hover:text-black">
                    <Icon name={item.icon} class="w-7 h-7" />
                  </div>
                </div>

                <h3 class="text-2xl font-bold text-white uppercase mb-4 tracking-tight group-hover:text-[#ffcc00] transition-colors z-10">
                  {item.title}
                </h3>
                
                <p class="text-gray-500 text-sm leading-relaxed mb-10 flex-grow group-hover:text-gray-300 z-10">
                  {item.desc}
                </p>

                <div class="relative z-10 inline-flex items-center gap-3 text-[#ffcc00] text-[10px] font-black uppercase tracking-[0.3em]">
                  Saber más
                  <Icon name="lucide:arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-2" />
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>