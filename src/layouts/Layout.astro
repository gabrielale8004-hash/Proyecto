---
import { Icon } from "astro-icon/components";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props; 
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Suministros Tesk</title>
    <link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,900;1,900&family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#050505] text-white font-['Inter'] antialiased">
    
    <!-- NAVBAR CON LOGO IMPACTANTE A LA IZQUIERDA -->
    <header class="fixed top-0 left-0 w-full z-[100] border-b border-white/5 bg-black/80 backdrop-blur-md">
      <!-- Línea de luz superior en tono Dorado -->
      <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-[#D4AF37] via-[#FFD700] to-transparent opacity-50"></div>
      
      <nav class="max-w-[1400px] mx-auto px-4 h-[80px] flex justify-between items-center">
        
        <!-- LOGO MÁS GRANDE Y PEGADO A LA IZQUIERDA -->
        <a href="/" class="flex flex-col group transition-all duration-300 active:scale-95">
          <span class="text-[#FFD700] font-['Archivo'] font-black text-4xl uppercase italic leading-[0.8] tracking-tighter drop-shadow-[0_0_15px_rgba(255,215,0,0.4)] group-hover:drop-shadow-[0_0_20px_rgba(255,215,0,0.6)] transition-all">
            TESK
          </span>
          <span class="text-white font-black text-[10px] uppercase tracking-[0.6em] mt-1 opacity-100 group-hover:text-[#FFD700] transition-colors">
            SUMINISTROS
          </span>
        </a>

        <!-- MENÚ CENTRAL REFINADO -->
        <div class="hidden md:flex items-center gap-12">
          <div class="flex flex-col items-center group cursor-pointer">
            <span class="text-[7px] text-[#FFD700] font-black tracking-widest opacity-0 group-hover:opacity-100 transition-all mb-0.5 italic">0.1</span>
            <a href="/" class="nav-link">Inicio</a>
          </div>
          <div class="flex flex-col items-center group cursor-pointer">
            <span class="text-[7px] text-[#FFD700] font-black tracking-widest opacity-0 group-hover:opacity-100 transition-all mb-0.5 italic">0.2</span>
            <a href="/products" class="nav-link">Productos</a>
          </div>
          <div class="flex flex-col items-center group cursor-pointer">
            <span class="text-[7px] text-[#FFD700] font-black tracking-widest opacity-0 group-hover:opacity-100 transition-all mb-0.5 italic">0.3</span>
            <a href="/contacts" class="nav-link">Contacto</a>
          </div>
        </div>

        <!-- STATUS INDUSTRIAL -->
        <div class="flex items-center gap-4 border-l border-white/10 pl-6 h-10">
           <div class="flex flex-col items-end leading-none">
              <span class="text-[#FFD700] text-[8px] font-black uppercase tracking-widest mb-1">Status: Online</span>
              <span class="text-white/40 text-[10px] font-bold uppercase tracking-tighter italic">Valencia, VZLA</span>
           </div>
           <div class="w-2 h-2 rounded-full bg-[#FFD700] shadow-[0_0_10px_#FFD700] animate-pulse"></div>
        </div>
      </nav>
    </header>

    <div class="h-[80px]"></div>

    <main>
      <slot />
    </main>

    <!-- FOOTER CON LOGO GIGANTE Y TONO DORADO -->
    <footer class="relative bg-[#050505] pt-20 pb-10 px-6 border-t border-white/5 overflow-hidden">
      <div class="max-w-[1400px] mx-auto relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-16 items-start">
          
          <!-- BRANDING DORADO REFORZADO -->
          <div class="space-y-6">
            <div class="flex flex-col">
              <h2 class="text-[#FFD700] font-['Archivo'] font-black text-6xl uppercase italic leading-[0.75] tracking-tighter drop-shadow-[0_0_20px_rgba(255,215,0,0.3)]">
                TESK
              </h2>
              <h2 class="text-white font-['Archivo'] font-black text-4xl uppercase leading-none tracking-tighter italic">
                SUMINISTROS
              </h2>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-12 h-[2px] bg-[#FFD700] shadow-[0_0_10px_#FFD700]"></div>
              <p class="text-white/40 text-[11px] font-black uppercase tracking-[0.4em]">Hardware & Engineering</p>
            </div>
          </div>

          <!-- INFORMACIÓN -->
          <div class="space-y-8 md:border-l border-white/5 md:pl-16">
            <div>
              <span class="text-[#FFD700] font-black text-[10px] uppercase tracking-[0.5em] block mb-3 italic">Ubicación</span>
              <p class="text-white text-sm font-bold uppercase tracking-widest leading-tight">Guacara, Edo. Carabobo.<br/>Venezuela.</p>
            </div>
            <div>
              <span class="text-[#FFD700] font-black text-[10px] uppercase tracking-[0.5em] block mb-3 italic">Contacto Directo</span>
              <a href="tel:+582455646129" class="text-2xl font-black italic tracking-tighter text-white hover:text-[#FFD700] transition-colors">
                +58 245 564 6129
              </a>
            </div>
          </div>

          <!-- REDES SOCIALES -->
          <div class="flex flex-col lg:items-end gap-8">
            <span class="text-white/20 font-black text-[10px] uppercase tracking-[0.6em] italic border-b border-[#FFD700]/30 pb-2">Conecta con nosotros</span>
            <div class="flex gap-5">
              
              <a href="https://instagram.com/tesksuministros" target="_blank" 
                 class="p-4 border border-white/10 rounded-2xl bg-white/[0.02] hover:bg-gradient-to-tr hover:from-[#f9ce34] hover:via-[#ee2a7b] hover:to-[#6228d7] transition-all duration-300 group">
                <Icon name="lucide:instagram" size={24} class="text-[#ee2a7b] group-hover:text-white transition-all scale-110" />
              </a>

              <a href="https://wa.me/582455646129" target="_blank" 
                 class="p-4 border border-white/10 rounded-2xl bg-white/[0.02] hover:bg-[#25D366] transition-all duration-300 group">
                <Icon name="lucide:message-circle-more" size={24} class="text-[#25D366] group-hover:text-white transition-all scale-110" />
              </a>

            </div>
          </div>

        </div>

        <div class="mt-20 pt-8 border-t border-white/5 flex justify-center">
          <span class="text-[9px] font-black uppercase tracking-[0.7em] text-white/20 italic">© 2026 TESK SUMINISTROS C.A.</span>
        </div>
      </div>
    </footer>

    <style is:global>
      @reference "../styles/global.css";

      .nav-link {
        @apply text-[11px] font-black uppercase tracking-[0.5em] text-white/40 hover:text-[#FFD700] transition-all duration-300 relative;
      }
      
      .nav-link::after {
        content: '';
        @apply absolute -bottom-1 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-[#FFD700] transition-all duration-300 shadow-[0_0_10px_#FFD700];
      }
      
      .nav-link:hover::after {
        @apply w-full;
      }

      html { 
        background: #050505; 
        -webkit-font-smoothing: antialiased; 
        scroll-behavior: smooth;
      }
      
      body { 
        margin: 0; 
      }
    </style>
  </body>
</html>