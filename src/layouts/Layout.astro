---
import "../styles/global.css";
import { Icon } from "astro-icon/components";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>Tesk Suministros</title>
    </head>
    <body>
        <header>
            <header class="barra">
                <p class="text-4xl">Tesk Suministros</p>

                <div class="enlaces">
                    <a href="/" class="home">Home</a>
                    <a href="/products">productos</a>
                    <a href="/contacts">Contactos</a>
                </div>

                <div class="iconos">
                    <Icon name="healthicons--magnifying-glass" size={20} />
                    <Icon name="typcn--shopping-cart" size={20} />
                </div>
            </header>

            <slot />
        </header>
    </body>

    <style>
        html,
        body {
            margin: 0;
            width: 100%;
            height: 100%;
            font-family: sans-serif;
        }

        .barra {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 50px;
            background: white;
            border-bottom: 1px solid #eee;
        }

        .barra p {
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .enlaces {
            display: flex;
            gap: 30px;
        }

        .enlaces a {
            text-decoration: none;
            color: #444;
            font-size: 14px;
            font-weight: bold;
            text-transform: uppercase;
        }

        .enlaces .home {
            color: #9c8414;
            border-bottom: 2px solid #9c8414;
        }

        .iconos {
            display: flex;
            gap: 15px;
            cursor: pointer;
        }
    </style>
</html>