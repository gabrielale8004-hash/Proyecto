---
import { Icon } from "astro-icon/components";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Tesk Suministros</title>
	</head>
	<body>
		<header class="flex justify-between px-12 py-5">
			<p class="text-black font-bold">Tesk Suministros</p>

			<div class="flex gap-10">
				<a href="/contacts" class="uppercase font-bold">Contactos</a>
				<a href="/products" class="uppercase font-bold">productos</a>
			</div>

			<div class="flex ">
				<Icon name="line-md--home-twotone" size={32} />

				<Icon name="eva--car-fill" size={32} />
				<button class="bg-amber-600 px-8 py-2 text font-bold">iniciar sesion</button>
			</div>
		</header>

		<slot />
	</body>

	<style>
		html,
		body {
			margin: 0;
			width: 100%;
			height: 100%;
		}
	</style>
</html>
